# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# PostgreSQL
POSTGRES_USER=ai_tagger
POSTGRES_PASSWORD=secret_password
POSTGRES_DB=ai_tagger
# Для Docker: postgres:5432
# Для локальной разработки: localhost:5433
DATABASE_URL=postgresql+asyncpg://ai_tagger:secret_password@postgres:5432/ai_tagger

# Ollama
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3
